The rotation count is the index of the smallest element in a rotated sorted array

logic
find pivot element 
return pivot +1 %arr.length (suppose the pivot element is appear in the last index i.e., the array is not rotated)


code


static int findPivot(int[] arr) {
        int start = 0;
        int end = arr.length - 1;

        while (start <= end) {
            int mid = start + (end - start) / 2;

            // Case 1
            if (mid < end && arr[mid] > arr[mid + 1]) {
                return mid;
            }

            // Case 2
            if (mid > start && arr[mid] < arr[mid - 1]) {
                return mid - 1;
            }

            // Search left
            if (arr[mid] <= arr[start]) {
                end = mid - 1;
            }
            // Search right
            else {
                start = mid + 1;
            }
        }

        return -1;
    }
}
