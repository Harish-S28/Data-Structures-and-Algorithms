class Solution {
    public char nextGreatestLetter(char[] letters, char target) {
        int s=0;
        int e=letters.length-1;
        while(s<=e){
            int mid=s+(e-s)/2;
            if(letters[mid]>target){
                e=mid-1;
            }
            else{
                s=mid+1;
            }
        }
        return letters[s%letters.length];
    }
}


//Logic
since we have to find the next greatest letter , so , if letter in mid less than target , move e=mid-1
otherwise s=mid+1
in the end , return letters[s%letters.length]. (using letters.length -> for 'z' character)
