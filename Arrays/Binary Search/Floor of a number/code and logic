// Floor of a number : Largest element less than or equal to the target.

// logic 
// do binary search
// if ans found return mid
// in the end return end pointer

// code 

public static int floor(int[] arr, int target) {
    int start = 0, end = arr.length - 1;

    if (target < arr[0]) return -1; // No floor exists

    while (start <= end) {
        int mid = start + (end - start) / 2;

        if (arr[mid] == target)
            return mid;

        if (target < arr[mid])
            end = mid - 1;
        else
            start = mid + 1;
    }

    return end;
}
